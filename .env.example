# Demerge Environment Configuration

# Application
APP_NAME=Demerge
APP_VERSION=1.0.0

# Supabase (Cloud Mode)
# Set these to enable Supabase PostgreSQL + Storage
SUPABASE_URL=https://wojaxqkgsxntyjtyohah.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# Backend URL
BACKEND_URL=https://demerge.vercel.app

# Document Configuration
REQUIRED_DOCUMENTS=offer_letter,nda,employment_contract
OPTIONAL_DOCUMENTS=job_description,company_policy
MAX_FILE_SIZE_MB=10

# CORS (comma-separated origins)
CORS_ORIGINS=https://demerge.vercel.app,http://localhost:5173

# ── Vercel Frontend Env Vars (set in Vercel dashboard) ──────────
# VITE_API_URL=https://demerge.vercel.app/api
# VITE_SUPABASE_URL=https://wojaxqkgsxntyjtyohah.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
