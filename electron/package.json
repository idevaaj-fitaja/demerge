{
  "name": "demerge",
  "version": "1.0.0",
  "description": "Demerge - PDF Document Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.demerge.app",
    "productName": "Demerge",
    "directories": {
      "output": "dist-bundle"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html"
    ],
    "extraResources": [
      {
        "from": "../venv-minimal",
        "to": "venv-minimal",
        "filter": ["**/*"]
      },
      {
        "from": "../app",
        "to": "app"
      },
      {
        "from": "../run.py",
        "to": "run.py"
      },
      {
        "from": "../.env",
        "to": ".env"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "icon.png",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "artifactName": "Demerge-${version}-${arch}.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico",
      "artifactName": "Demerge-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico"
    },
    "afterPack": null
  }
}
